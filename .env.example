# Cloud LLM provider (Approach 1 - public cloud API)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001

# MCP server auth (token-based, must support revocation)
COP_MCP_AUTH_TOKEN=
THIEF_MCP_AUTH_TOKEN=
# Where revoked tokens are recorded; checked on every request, no restart
# needed to take effect. Defaults to data/revoked_tokens.json if unset.
REVOKED_TOKENS_PATH=./data/revoked_tokens.json

# MCP server URLs (filled in once deployed to the cloud)
COP_MCP_URL=
THIEF_MCP_URL=

# Gmail API (Google Cloud project OAuth client)
GMAIL_CLIENT_SECRET_PATH=./secrets/client_secret.json
GMAIL_TOKEN_PATH=./secrets/token.json
# Real recipient is config.yaml: reporting.recipient_email (the lecturer's
# address). Set this to your own email to redirect a TEST send to
# yourself instead -- remove it for the real final run.
REPORT_RECIPIENT_OVERRIDE=

# Optional: local Ollama (Approach 2/3)
OLLAMA_BASE_URL=http://127.0.0.1:11434
